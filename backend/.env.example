# -----------------------------------------------------------------------
# Amazon Review Insights — Backend environment variables
# Copy this file to .env and fill in values before running locally.
# Never commit the real .env file to version control.
# -----------------------------------------------------------------------

# HuggingFace model used for sentiment analysis.
# Any text-classification model on the Hub works here.
# Default: distilbert-base-uncased-finetuned-sst-2-english
MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english

# Maximum number of reviews accepted in a single /analyze/batch request.
MAX_BATCH_SIZE=32

# Maximum token length passed to the transformer pipeline.
MAX_TEXT_LENGTH=512

# (Optional) OpenAI API key — enables AI-powered /summarize endpoint.
# Leave blank to use the deterministic extractive fallback.
OPENAI_API_KEY=

# (Optional) OpenAI model used for summarization (default: gpt-3.5-turbo).
OPENAI_MODEL=gpt-3.5-turbo

# (Optional) Maximum tokens in the OpenAI summary response.
OPENAI_MAX_TOKENS=256

# Application metadata
APP_NAME=Amazon Review Insights API
APP_VERSION=1.0.0

# Set to "true" to enable verbose/debug logging.
DEBUG=false
